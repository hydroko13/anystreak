<AnchorLayout>:
    anchor_x: 'center'
    anchor_y: 'center'
    BoxLayout:

        orientation: 'vertical'
        size_hint: None, None
        size: 300, 300
        spacing: 20

        Label:
            text: "AnyStreak"
            font_size: 64
            color: 0.92, 0.92, 0.92        

        Button:
            text: "[ + ] Start New"
            font_size: 40
 